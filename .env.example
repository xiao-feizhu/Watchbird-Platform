# ============================================
# Database Configuration
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For Docker Compose: use 'db' as hostname (service name)
DATABASE_URL="postgresql://postgres:postgres@db:5432/watchbird?schema=public"

# Database credentials for docker-compose (optional - defaults shown)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=watchbird

# ============================================
# NextAuth Configuration
# ============================================
# Your production domain
NEXTAUTH_URL="http://localhost:3000"

# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-this-in-production"

# ============================================
# JWT Configuration (if using custom JWT)
# ============================================
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"

# ============================================
# WeChat Pay Configuration (Optional for MVP)
# ============================================
# WeChat App ID for OAuth
WECHAT_APP_ID=""

# WeChat App Secret for OAuth
WECHAT_APP_SECRET=""

# WeChat Merchant ID for payments
WECHAT_MCH_ID=""

# WeChat API Key for payments
WECHAT_API_KEY=""

# ============================================
# Redis Configuration (Optional)
# ============================================
# For caching and session storage
REDIS_URL=""

# ============================================
# Tencent COS Configuration (Optional)
# ============================================
# For image/file storage
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-guangzhou"

# ============================================
# Next.js Public Variables
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3000"
