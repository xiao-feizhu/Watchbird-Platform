generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  WATCHER
  GUIDE
  ADMIN
}

enum GuideLevel {
  BASIC
  ADVANCED
  GOLD
  PREMIUM
}

enum GuideStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ServiceType {
  STANDARD
  CUSTOM
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_CONFIRM
  CONFIRMED
  IN_SERVICE
  PENDING_REVIEW
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ReviewAuditStatus {
  PENDING
  PASSED
  REJECTED
}

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  nickname      String?
  avatar        String?
  role          UserRole  @default(WATCHER)
  password      String?
  wechatOpenId  String?   @unique @map("wechat_open_id")
  wechatUnionId String?   @map("wechat_union_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  guideProfile  GuideProfile?
  orders        Order[]
  reviewsGiven  Review[]  @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")

  // 新增关联（鸟友组队功能）
  userProfile        UserProfile?
  tripParticipants   TripParticipant[]
  chatMessages       ChatMessage[]
  tripsOrganized     Trip[] @relation("TripsOrganized")
  follows            Follow[] @relation("UserFollows")
  followers          Follow[] @relation("UserFollowers")

  @@map("users")
}

model GuideProfile {
  id              String      @id @default(uuid())
  userId          String      @unique @map("user_id")
  type            String      @default("individual")
  level           GuideLevel  @default(BASIC)
  status          GuideStatus @default(PENDING)
  realName        String      @map("real_name")
  idCard          String?     @map("id_card")
  bio             String?
  regions         String[]
  languages       String[]    @default(["中文"])
  commissionRate  Decimal     @default(0.15) @map("commission_rate")

  contactPhone    String      @map("contact_phone")
  contactWechat   String?     @map("contact_wechat")
  contactEmail    String?     @map("contact_email")

  certificates    String[]

  totalOrders     Int         @default(0) @map("total_orders")
  completedOrders Int         @default(0) @map("completed_orders")
  rating          Decimal     @default(5.0) @db.Decimal(2, 1)
  reviewCount     Int         @default(0) @map("review_count")

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  services        ServiceProduct[]
  orders          Order[]

  @@map("guide_profiles")
}

model ServiceProduct {
  id            String        @id @default(uuid())
  guideId       String        @map("guide_id")
  type          ServiceType   @default(STANDARD)
  title         String
  description   String
  region        String
  duration      Int
  maxPeople     Int           @map("max_people")
  price         Decimal       @db.Decimal(10, 2)
  priceType     String        @default("per_person") @map("price_type")

  includes      String[]
  excludes      String[]
  birdSpecies   String[]      @map("bird_species")
  bestSeason    String[]      @map("best_season")

  images        String[]

  status        ServiceStatus @default(DRAFT)

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  guide         GuideProfile  @relation(fields: [guideId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@map("service_products")
}

model Order {
  id            String      @id @default(uuid())
  orderNo       String      @unique @map("order_no")

  userId        String      @map("user_id")
  guideId       String      @map("guide_id")
  productId     String      @map("product_id")

  type          ServiceType
  serviceDate   DateTime    @map("service_date")
  peopleCount   Int         @map("people_count")
  totalPrice    Decimal     @db.Decimal(10, 2) @map("total_price")
  status        OrderStatus @default(PENDING_PAYMENT)

  userRemark    String?     @map("user_remark")
  guideRemark   String?     @map("guide_remark")

  paidAt        DateTime?   @map("paid_at")
  confirmedAt   DateTime?   @map("confirmed_at")
  completedAt   DateTime?   @map("completed_at")
  cancelledAt   DateTime?   @map("cancelled_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user          User        @relation(fields: [userId], references: [id])
  guide         GuideProfile @relation(fields: [guideId], references: [id])
  product       ServiceProduct @relation(fields: [productId], references: [id])
  payment       Payment?
  reviews       Review[]

  @@map("orders")
}

model Payment {
  id            String    @id @default(uuid())
  orderId       String    @unique @map("order_id")

  wechatOrderId String?   @map("wechat_order_id")
  prepayId      String?   @map("prepay_id")

  amount        Decimal   @db.Decimal(10, 2)
  status        String

  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id            String            @id @default(uuid())
  orderId       String            @map("order_id")
  reviewerId    String            @map("reviewer_id")
  revieweeId    String            @map("reviewee_id")

  rating        Int
  content       String
  tags          String[]
  images        String[]
  reply         String?
  repliedAt     DateTime?         @map("replied_at")

  auditStatus   ReviewAuditStatus @default(PENDING) @map("audit_status")
  auditRemark   String?           @map("audit_remark")

  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  order         Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer      User              @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee      User              @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@map("reviews")
}

// ==================== 鸟友组队功能新增模型 ====================

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FeeType {
  FREE
  AA
  FIXED
}

enum TripStatus {
  OPEN       // 招募中
  FULL       // 已满员
  CLOSED     // 已截止
  COMPLETED  // 已完成
  CANCELLED  // 已取消
}

enum ParticipantStatus {
  PENDING   // 申请中
  APPROVED  // 已通过
  REJECTED  // 已拒绝
  CANCELLED // 已取消
}

enum ChatGroupStatus {
  ACTIVE    // 正常
  DISABLED  // 已禁言
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
}

enum NotificationType {
  TRIP_APPLICATION
  TRIP_APPROVED
  TRIP_REJECTED
  TRIP_CANCELLED
  NEW_MEMBER
  NEW_MESSAGE
  TRIP_REMINDER
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  age           Int?
  gender        Gender?
  region        String?
  bio           String?  @db.Text

  birdingYears  Int      @default(0) @map("birding_years")
  expertBirds   String[] @map("expert_birds")
  equipment     String?

  canDrive      Boolean  @default(false) @map("can_drive")
  carCapacity   Int      @default(0) @map("car_capacity")

  hostedTrips   Int      @default(0) @map("hosted_trips")
  joinedTrips   Int      @default(0) @map("joined_trips")
  followers     Int      @default(0)
  following     Int      @default(0)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model Trip {
  id              String     @id @default(uuid())
  organizerId     String     @map("organizer_id")
  organizer       User       @relation("TripsOrganized", fields: [organizerId], references: [id], onDelete: Cascade)

  title           String
  destination     String
  destinationLat  Float?     @map("destination_lat")
  destinationLng  Float?     @map("destination_lng")
  startDate       DateTime   @map("start_date")
  endDate         DateTime?  @map("end_date")
  maxParticipants Int        @map("max_participants")
  currentCount    Int        @default(1) @map("current_count")

  requirements    String?    @db.Text

  feeType         FeeType    @default(AA) @map("fee_type")
  feeAmount       Decimal?   @db.Decimal(10, 2) @map("fee_amount")
  feeDescription  String?    @map("fee_description")

  description     String     @db.Text
  status          TripStatus @default(OPEN)

  participants    TripParticipant[]
  chatGroup       ChatGroup?

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([status, startDate])
  @@index([destination])
  @@index([organizerId])
  @@map("trips")
}

model TripParticipant {
  id            String             @id @default(uuid())
  tripId        String             @map("trip_id")
  trip          Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId        String             @map("user_id")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        ParticipantStatus  @default(PENDING)

  bio           String?            @db.Text

  appliedAt     DateTime           @default(now()) @map("applied_at")
  respondedAt   DateTime?          @map("responded_at")

  @@unique([tripId, userId])
  @@index([userId, status])
  @@map("trip_participants")
}

model ChatGroup {
  id             String          @id @default(uuid())
  tripId         String          @unique @map("trip_id")
  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name           String
  status         ChatGroupStatus @default(ACTIVE)
  disabledAt     DateTime?       @map("disabled_at")
  disabledReason String?         @map("disabled_reason")
  createdAt      DateTime        @default(now()) @map("created_at")

  messages       ChatMessage[]

  @@map("chat_groups")
}

model ChatMessage {
  id          String      @id @default(uuid())
  groupId     String      @map("group_id")
  group       ChatGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId    String      @map("sender_id")
  sender      User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content     String      @db.Text
  messageType MessageType @default(TEXT) @map("message_type")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([groupId, createdAt])
  @@map("chat_messages")
}

model Follow {
  id          String    @id @default(uuid())
  followerId  String    @map("follower_id")
  follower    User      @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String    @map("following_id")
  following   User      @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@map("follows")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  content     String?
  data        Json?
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}
